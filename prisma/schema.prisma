// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum OrderStatus {
  PENDING
  CONFIRMED
  UPLOADED
  APPROVED
  READY
  IN_PRODUCTION
  DONE
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum DeliveryType {
  STANDARD
  EXPRESS
  PICKUP
}

enum FileStatus {
  PENDING
  APPROVED
  REJECTED
}

enum JobStatus {
  QUEUED
  IN_PROGRESS
  DONE
  FAILED
}

// ---------------------------------------------------------------------------
// User
// ---------------------------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())

  cart   Cart?
  orders Order[]
}

// ---------------------------------------------------------------------------
// Product categories
// ---------------------------------------------------------------------------

model ProductCategory {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  sortOrder Int       @default(0)

  products  Product[]
}

// ---------------------------------------------------------------------------
// Product catalogue
// ---------------------------------------------------------------------------

model Product {
  id         String  @id @default(cuid())
  name       String
  slug       String  @unique
  category   String
  categoryId String?
  active     Boolean @default(true)

  guideText        String?
  minDpi           Int?
  recommendedDpi   Int?
  bleedMm          Float?
  safeMarginMm     Float?
  allowedFormats   String?
  notes            String?

  variants         ProductVariant[]
  options          ProductOption[]
  pricingRules     PricingRule[]
  pricingTables    PricingTable[]
  cartItems        CartItem[]
  mockupTemplates  MockupTemplate[]
  config           ProductConfig?
  productCategory  ProductCategory? @relation(fields: [categoryId], references: [id])
}

// ---------------------------------------------------------------------------
// Product configuration rules
// ---------------------------------------------------------------------------

model ProductConfig {
  id              String  @id @default(cuid())
  productId       String  @unique

  type            String
  hasCustomSize   Boolean @default(false)
  hasFixedSizes   Boolean @default(false)
  hasVariants     Boolean @default(false)
  hasOptions      Boolean @default(false)

  fixedSizes      String?
  minWidth        Float?
  maxWidth        Float?
  minHeight       Float?
  maxHeight       Float?

  printWidth      Float?
  printHeight     Float?

  pricingType     String?
  pickupAllowed   Boolean?

  maxWidthCm      Decimal? @db.Decimal(8, 2)
  maxHeightCm     Decimal? @db.Decimal(8, 2)
  rollWidthCm     Decimal? @db.Decimal(8, 2)
  dtfMaxWidthCm   Decimal? @db.Decimal(8, 2)
  cutOnly         Boolean  @default(false)
  printAndCut     Boolean  @default(false)
  needsUpload     Boolean  @default(true)
  priceMode       String?

  printAreaWidthCm  Decimal? @db.Decimal(8, 2)
  printAreaHeightCm Decimal? @db.Decimal(8, 2)
  placementMode     String?

  isTextile      Boolean @default(false)
  isRoll         Boolean @default(false)
  isCut          Boolean @default(false)
  isPrintCut     Boolean @default(false)
  isDTF          Boolean @default(false)
  needsPlacement Boolean @default(false)

  notes           String?

  product Product @relation(fields: [productId], references: [id])
}

// ---------------------------------------------------------------------------
// Pricing tables
// ---------------------------------------------------------------------------

model PricingTable {
  id        String  @id @default(cuid())
  productId String

  type      String

  minQty    Int?
  maxQty    Int?

  minWidth  Float?
  maxWidth  Float?

  minHeight Float?
  maxHeight Float?

  price       Decimal  @db.Decimal(10, 2)
  pricePerM2  Decimal? @db.Decimal(10, 2)

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  name      String
  material  String
  basePrice Decimal @db.Decimal(10, 2)

  product   Product    @relation(fields: [productId], references: [id])
  cartItems CartItem[]

  @@index([productId])
}

model ProductOption {
  id        String @id @default(cuid())
  productId String
  name      String

  product Product              @relation(fields: [productId], references: [id])
  values  ProductOptionValue[]

  @@index([productId])
}

model ProductOptionValue {
  id            String  @id @default(cuid())
  optionId      String
  name          String
  priceModifier Decimal @default(0) @db.Decimal(10, 2)

  option ProductOption @relation(fields: [optionId], references: [id])

  @@index([optionId])
}

// ---------------------------------------------------------------------------
// Pricing
// ---------------------------------------------------------------------------

model PricingRule {
  id                String  @id @default(cuid())
  productId         String
  pricePerM2        Decimal @db.Decimal(10, 2)
  minPrice          Decimal @db.Decimal(10, 2)
  expressMultiplier Decimal @default(1.5) @db.Decimal(4, 2)

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
}

// ---------------------------------------------------------------------------
// Shipping rules
// ---------------------------------------------------------------------------

model ShippingRule {
  id         String   @id @default(cuid())
  type       String
  minTotal   Decimal? @db.Decimal(10, 2)
  price      Decimal? @db.Decimal(10, 2)
  multiplier Decimal? @db.Decimal(4, 2)
}

// ---------------------------------------------------------------------------
// Cart
// ---------------------------------------------------------------------------

model Cart {
  id     String @id @default(cuid())
  userId String @unique

  user  User       @relation(fields: [userId], references: [id])
  items CartItem[]
}

model CartItem {
  id            String  @id @default(cuid())
  cartId        String
  productId     String
  variantId     String?
  width         Decimal @db.Decimal(8, 2)
  height        Decimal @db.Decimal(8, 2)
  quantity      Int
  priceSnapshot Decimal @db.Decimal(10, 2)
  express       Boolean @default(false)
  placement     String?

  cart    Cart            @relation(fields: [cartId], references: [id])
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([cartId])
  @@index([productId])
}

// ---------------------------------------------------------------------------
// Order  (snapshot — intentionally denormalized)
// ---------------------------------------------------------------------------

model Order {
  id                String        @id @default(cuid())
  userId            String
  total             Decimal       @db.Decimal(10, 2)
  shippingPrice     Decimal       @db.Decimal(10, 2) @default(0)
  expressMultiplier Decimal       @db.Decimal(4, 2)  @default(1.5)
  status            OrderStatus   @default(PENDING)
  paymentStatus     PaymentStatus @default(UNPAID)
  deliveryType      DeliveryType  @default(STANDARD)
  createdAt         DateTime      @default(now())

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@index([userId])
}

model OrderItem {
  id            String  @id @default(cuid())
  orderId       String
  productName   String
  variantName   String?
  categoryName  String?
  width         Decimal @db.Decimal(8, 2)
  height        Decimal @db.Decimal(8, 2)
  quantity      Int
  priceSnapshot Decimal @db.Decimal(10, 2)
  previewUrl    String?

  order         Order          @relation(fields: [orderId], references: [id])
  uploadFiles   UploadFile[]
  productionJob ProductionJob?

  @@index([orderId])
}

// ---------------------------------------------------------------------------
// Mockup templates
// ---------------------------------------------------------------------------

model MockupTemplate {
  id               String  @id @default(cuid())
  productId        String
  name             String
  imageUrl         String
  printAreaX       Float?
  printAreaY       Float?
  printAreaWidth   Float?
  printAreaHeight  Float?

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
}

// ---------------------------------------------------------------------------
// File uploads
// ---------------------------------------------------------------------------

model UploadFile {
  id          String     @id @default(cuid())
  orderItemId String
  filename    String
  filePath    String?
  size        Int?
  mime        String?
  dpi         Int?
  widthPx     Int?
  heightPx    Int?
  status      FileStatus @default(PENDING)

  orderItem OrderItem @relation(fields: [orderItemId], references: [id])

  @@index([orderItemId])
}

// ---------------------------------------------------------------------------
// Production
// ---------------------------------------------------------------------------

model ProductionJob {
  id          String    @id @default(cuid())
  orderItemId String    @unique
  status      JobStatus @default(QUEUED)
  machine     String?
  notes       String?

  orderItem OrderItem @relation(fields: [orderItemId], references: [id])
}
