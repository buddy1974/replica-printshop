// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum OrderStatus {
  PENDING
  CONFIRMED
  UPLOADED
  APPROVED
  READY
  IN_PRODUCTION
  DONE
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum DeliveryType {
  STANDARD
  EXPRESS
  PICKUP
}

enum FileStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_FIX
}

enum JobStatus {
  QUEUED
  IN_PROGRESS
  DONE
  FAILED
}

// ---------------------------------------------------------------------------
// User
// ---------------------------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  cart      Cart?
  orders    Order[]
  addresses Address[]
}

// ---------------------------------------------------------------------------
// Addresses (saved by registered users)
// ---------------------------------------------------------------------------

model Address {
  id      String  @id @default(cuid())
  userId  String
  name    String
  company String?
  street  String
  zip     String
  city    String
  country String
  phone   String?

  user           User    @relation(fields: [userId], references: [id])
  billingOrders  Order[] @relation("billingAddress")
  shippingOrders Order[] @relation("shippingAddress")

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Product categories
// ---------------------------------------------------------------------------

model ProductCategory {
  id               String    @id @default(cuid())
  name             String
  slug             String    @unique
  sortOrder        Int       @default(0)
  defaultPriceMode String?
  allowShipping    Boolean   @default(true)
  allowPickup      Boolean   @default(true)
  description     String?
  imageUrl        String?
  metaTitle       String?
  metaDescription String?

  products  Product[]
}

// ---------------------------------------------------------------------------
// Product catalogue
// ---------------------------------------------------------------------------

model Product {
  id         String  @id @default(cuid())
  name       String
  slug       String  @unique
  category   String
  categoryId String?
  active     Boolean @default(true)

  description      String?
  shortDescription String?
  imageUrl         String?
  metaTitle        String?
  metaDescription  String?
  guideText        String?
  minDpi           Int?
  recommendedDpi   Int?
  bleedMm          Float?
  safeMarginMm     Float?
  allowedFormats   String?
  notes            String?
  specs            Json?

  variants         ProductVariant[]
  options          ProductOption[]
  pricingRules     PricingRule[]
  pricingTables    PricingTable[]
  cartItems        CartItem[]
  mockupTemplates  MockupTemplate[]
  config           ProductConfig?
  productCategory  ProductCategory? @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
}

// ---------------------------------------------------------------------------
// Product configuration rules
// ---------------------------------------------------------------------------

model ProductConfig {
  id              String  @id @default(cuid())
  productId       String  @unique

  type            String
  hasCustomSize   Boolean @default(false)
  hasFixedSizes   Boolean @default(false)
  hasVariants     Boolean @default(false)
  hasOptions      Boolean @default(false)

  fixedSizes      String?
  minWidth        Float?
  maxWidth        Float?
  minHeight       Float?
  maxHeight       Float?

  printWidth      Float?
  printHeight     Float?

  pricingType     String?
  pickupAllowed   Boolean?

  maxWidthCm      Decimal? @db.Decimal(8, 2)
  maxHeightCm     Decimal? @db.Decimal(8, 2)
  rollWidthCm     Decimal? @db.Decimal(8, 2)
  dtfMaxWidthCm   Decimal? @db.Decimal(8, 2)
  cutOnly         Boolean  @default(false)
  printAndCut     Boolean  @default(false)
  needsUpload     Boolean  @default(true)
  priceMode       String?

  printAreaWidthCm  Decimal? @db.Decimal(8, 2)
  printAreaHeightCm Decimal? @db.Decimal(8, 2)
  placementMode     String?

  isTextile      Boolean @default(false)
  isRoll         Boolean @default(false)
  isCut          Boolean @default(false)
  isPrintCut     Boolean @default(false)
  isDTF          Boolean @default(false)
  needsPlacement Boolean @default(false)

  productionType     String?
  setupPrice         Decimal? @db.Decimal(10, 2)
  shippingRequired   Boolean  @default(true)
  helpText           String?
  uploadInstructions String?

  allowedPositions String?  // JSON: ["front","back","left-chest","right-chest","sleeve"]

  notes            String?

  product Product @relation(fields: [productId], references: [id])
}

// ---------------------------------------------------------------------------
// Pricing tables
// ---------------------------------------------------------------------------

model PricingTable {
  id        String  @id @default(cuid())
  productId String

  type      String

  minQty    Int?
  maxQty    Int?

  minWidth  Float?
  maxWidth  Float?

  minHeight Float?
  maxHeight Float?

  price        Decimal  @db.Decimal(10, 2)
  pricePerM2   Decimal? @db.Decimal(10, 2)
  pricePerMeter Decimal? @db.Decimal(10, 2)

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  name      String
  material  String
  basePrice Decimal @db.Decimal(10, 2)

  product   Product    @relation(fields: [productId], references: [id])
  cartItems CartItem[]

  @@index([productId])
}

model ProductOption {
  id        String @id @default(cuid())
  productId String
  name      String

  product Product              @relation(fields: [productId], references: [id])
  values  ProductOptionValue[]

  @@index([productId])
}

model ProductOptionValue {
  id            String   @id @default(cuid())
  optionId      String
  name          String
  priceModifier Decimal  @default(0) @db.Decimal(10, 2)
  multiplier    Decimal? @db.Decimal(6, 4)

  option ProductOption @relation(fields: [optionId], references: [id])

  @@index([optionId])
}

// ---------------------------------------------------------------------------
// Pricing
// ---------------------------------------------------------------------------

model PricingRule {
  id                String  @id @default(cuid())
  productId         String
  pricePerM2        Decimal @db.Decimal(10, 2)
  minPrice          Decimal @db.Decimal(10, 2)
  expressMultiplier Decimal @default(1.5) @db.Decimal(4, 2)

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
}

// ---------------------------------------------------------------------------
// Shipping rules + methods
// ---------------------------------------------------------------------------

model ShippingRule {
  id         String   @id @default(cuid())
  type       String
  minTotal   Decimal? @db.Decimal(10, 2)
  price      Decimal? @db.Decimal(10, 2)
  multiplier Decimal? @db.Decimal(4, 2)
}

model ShippingMethod {
  id     String  @id @default(cuid())
  name   String
  price  Decimal @default(0) @db.Decimal(10, 2)
  type   String
  active Boolean @default(true)

  orders Order[]
}

// ---------------------------------------------------------------------------
// Cart
// ---------------------------------------------------------------------------

model Cart {
  id     String @id @default(cuid())
  userId String @unique

  user  User       @relation(fields: [userId], references: [id])
  items CartItem[]
}

model CartItem {
  id              String  @id @default(cuid())
  cartId          String
  productId       String
  variantId       String?
  designId        String?
  pendingUploadId String? @unique
  width           Decimal @db.Decimal(8, 2)
  height          Decimal @db.Decimal(8, 2)
  quantity        Int
  priceSnapshot   Decimal @db.Decimal(10, 2)
  express         Boolean @default(false)
  placement       String?

  cart          Cart            @relation(fields: [cartId], references: [id])
  product       Product         @relation(fields: [productId], references: [id])
  variant       ProductVariant? @relation(fields: [variantId], references: [id])
  design        Design?         @relation(fields: [designId], references: [id])
  pendingUpload PendingUpload?  @relation(fields: [pendingUploadId], references: [id])

  @@index([cartId])
  @@index([productId])
}

// ---------------------------------------------------------------------------
// Pending upload (pre-checkout, linked to cart item)
// ---------------------------------------------------------------------------

model PendingUpload {
  id          String   @id @default(cuid())
  userId      String?
  filename    String
  filePath    String?
  size        Int?
  mime        String?
  dpi         Int?
  widthPx     Int?
  heightPx    Int?
  validStatus String   @default("PENDING")
  createdAt   DateTime @default(now())

  cartItem CartItem?

  @@index([userId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Design  (step 351)
// ---------------------------------------------------------------------------

model Design {
  id        String   @id @default(cuid())
  userId    String?
  productId String
  data      Json
  preview   String?
  createdAt DateTime @default(now())

  cartItems CartItem[]

  @@index([userId])
  @@index([productId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Order  (snapshot — intentionally denormalized)
// ---------------------------------------------------------------------------

model Order {
  id                String        @id @default(cuid())
  userId            String?
  total             Decimal       @db.Decimal(10, 2)
  shippingPrice     Decimal       @db.Decimal(10, 2) @default(0)
  expressMultiplier Decimal       @db.Decimal(4, 2)  @default(1.5)
  status            OrderStatus   @default(PENDING)
  paymentStatus     PaymentStatus @default(UNPAID)
  deliveryType      DeliveryType  @default(STANDARD)
  shippingMethodId  String?
  billingAddressId  String?
  shippingAddressId String?

  // Inline guest address fields
  billingName       String?
  billingStreet     String?
  billingCity       String?
  billingZip        String?
  billingCountry    String?
  shippingName      String?
  shippingStreet    String?
  shippingCity      String?
  shippingZip       String?
  shippingCountry   String?

  stripePaymentIntentId String? @unique
  createdAt             DateTime @default(now())

  user            User?           @relation(fields: [userId], references: [id])
  shippingMethod  ShippingMethod? @relation(fields: [shippingMethodId], references: [id])
  billingAddress  Address?        @relation("billingAddress",  fields: [billingAddressId],  references: [id])
  shippingAddress Address?        @relation("shippingAddress", fields: [shippingAddressId], references: [id])
  items           OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id                      String  @id @default(cuid())
  orderId                 String
  productName             String
  variantName             String?
  categoryName            String?
  productionTypeSnapshot  String?
  productId               String?
  variantId               String?
  width                   Decimal @db.Decimal(8, 2)
  height                  Decimal @db.Decimal(8, 2)
  quantity                Int
  priceSnapshot           Decimal @db.Decimal(10, 2)
  previewUrl              String?
  designId                String?

  order         Order          @relation(fields: [orderId], references: [id])
  uploadFiles   UploadFile[]
  productionJob ProductionJob?

  @@index([orderId])
}

// ---------------------------------------------------------------------------
// Mockup templates
// ---------------------------------------------------------------------------

model MockupTemplate {
  id               String  @id @default(cuid())
  productId        String
  name             String
  imageUrl         String
  printAreaX       Float?
  printAreaY       Float?
  printAreaWidth   Float?
  printAreaHeight  Float?

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
}

// ---------------------------------------------------------------------------
// File uploads
// ---------------------------------------------------------------------------

model UploadFile {
  id           String     @id @default(cuid())
  orderItemId  String
  filename     String
  filePath     String?
  size         Int?
  mime         String?
  dpi          Int?
  widthPx      Int?
  heightPx     Int?
  status       FileStatus @default(PENDING)
  uploadType   String?
  uploadIndex  Int?

  orderItem OrderItem @relation(fields: [orderItemId], references: [id])

  @@index([orderItemId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Audit + error log  (steps 331, 337)
// ---------------------------------------------------------------------------

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  data      Json?
  createdAt DateTime @default(now())

  @@index([action])
  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

model ErrorLog {
  id        String   @id @default(cuid())
  message   String
  stack     String?
  path      String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Production
// ---------------------------------------------------------------------------

model ProductionJob {
  id          String    @id @default(cuid())
  orderItemId String    @unique
  status      JobStatus @default(QUEUED)
  machine     String?
  machineType String?
  notes       String?
  createdAt   DateTime  @default(now())

  orderItem OrderItem @relation(fields: [orderItemId], references: [id])

  @@index([status])
  @@index([machineType])
}
