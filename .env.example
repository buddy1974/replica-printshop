# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=https://replica.print
NODE_ENV=production

# ── Storage ───────────────────────────────────────────────────────────────────
# Absolute path for upload storage. Defaults to <cwd>/storage/uploads if unset.
UPLOAD_DIR=
MAX_UPLOAD_SIZE=52428800

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
ADMIN_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@replica.printshop
